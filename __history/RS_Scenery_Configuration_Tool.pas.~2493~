procedure TMainForm.TKPKCompatibilityToggleSwitchClick(Sender: TObject);
var Rslt : TSearchRec;
begin
  If TKPKCompatibilityToggleSwitch.Enabled = true then
  begin
    If TKPKCompatibilityToggleSwitch.state =tssOn then
    begin
      //make backups
      If FindFirst(T2GTKPKPath+'texture\T2G originals\*.agn',faAnyFile,Rslt) <>0 then
      begin
        System.SysUtils.ForceDirectories(T2GTKPKPath+'texture\T2G originals\');
        CopyFiles(T2GTKPKPath+'texture\*.agn', T2GTKPKPath+'texture\T2G originals\', FOF_NOCONFIRMATION)
      end;
      FindClose(Rslt);

      //copy fixed autogen over
      try
      begin
        CopyFiles(SKNInstallLocation+'texture\T2G SKN Fix\*.agn', T2GTKPKPath+'texture\', FOF_NOCONFIRMATION);
        //ShowMessage('Fix applied');
      end;
      except
       MessageDlg('Fix could not be applied', mtWarning, [mbOK],0);
      end;
    end
    else
    begin
      try
      begin
        //determine whether a backup is present
        If FindFirst(T2GTKPKPath+'texture\T2G originals\*.agn',faAnyFile,Rslt)=0  then
        begin
          //copy them back
          CopyFiles(T2GTKPKPath+'texture\T2G originals\*.agn', T2GTKPKPath+'texture\', FOF_NOCONFIRMATION);
          //ShowMessage('Original autogen restored.');
        end;
        FindClose(Rslt);
      end;
      except
        MessageDlg('Original autogen could not be restored. Backup can be found in texture folder.', mtError, [mbOK], 0);
      end;
    end;
  end;
end;


