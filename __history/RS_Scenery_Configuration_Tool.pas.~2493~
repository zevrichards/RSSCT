procedure TMainForm.NetHTTPRequestReceiveData(const Sender: TObject;
  AContentLength, AReadCount: Int64; var Abort: Boolean);
var
  LTime, LSpeed, mins, secs: Cardinal;
  LSize, LRead, timeleft: double;


begin

  ////////////////////////////////////////
  //SettingsPageControl.ActivePageIndex := 7;
  ////////////////////////////////////////
//  CancelDownloadButton.Enabled := true;

  LTime := TThread.GetTickCount - FGlobalStart;
  LSpeed := (AReadCount) div LTime;
  LSize :=  AContentLength / (1024*1024);
  LRead :=  AReadCount / (1024*1024);
  If Lspeed > 0 then
  begin
    timeleft:= (((AContentLength-AreadCount)/1024)/Lspeed)/60;
    mins:= trunc(timeleft);
    secs:= trunc(frac(timeleft)*60);
  end;

//there seems to be an Access violation here. I am assuming that AContentLength is to big for aProgressBar.Max?
  If AContentLength > MaxInt then
  begin
    ProgressBarDownload.Max := MaxInt;
    ProgressBarDownload2.Max := MaxInt;
  end
  else
  begin
    If AContentLength > 0 then
    begin
     ProgressBarDownload.Max := AContentLength;
     ProgressBarDownload2.Max := AContentLength;
    end;
  end;

  TThread.Queue(nil,
    procedure
    begin

      ProgressBarDownload.position := AReadCount;
      ProgressBarDownload2.position := AReadCount;
      LabelGlobalSpeed.caption := 'Downloading: '+downloadedfilename+Format('. %n MB of %n MB', [LRead, LSize])+ Format(' @ %d KB/s.', [LSpeed]) + Format(' %.0d:', [mins])+ Format('%.2d left', [secs]);
      //Memo1.Lines.Add('Receiving Data...');
      ReceivingData := true;
      CheckForUpdatesButton.Enabled := false;
      DataReceived := false;
      //Memo1.Lines.Add('ReceivingData:= TRUE;');
    end);


end;

procedure TMainForm.NetHTTPRequestRequestCompleted(const Sender: TObject;
  const AResponse: IHTTPResponse);
var FResponseData: TMemoryStream;
    TaskRequestCompleted: ITask;
    LResponse: IHTTPResponse;
    //LSize: Int64;

    {currentScenery, newScenery,} CurrentManager, NewManager: integer;
    CurrentPatch, newPatch: TArray<Integer>;
    c, n: string;

begin
//  CancelDownloadButton.Enabled := false;
  TThread.Synchronize(nil,
            procedure
            begin
            GifChange(false)
            end);

  LResponse := AResponse;
//  LSize := AResponse.ContentLength;
  Memo1.Lines.Add(Format('Head response: %d - %s', [LResponse.StatusCode, LResponse.StatusText]));
  //Memo1.Lines.Add(Format('Downloaded %d MB', [AResponse.ContentLength div (1024*1024)]));
  If (LResponse.StatusCode <> 200) and (MirrorAttempt = false) then
  begin
    Memo1.Lines.Add('Server returned status code: '+IntToStr(LResponse.StatusCode)+' Trying Mirror...');
    TryMirror;
    exit;
  end;

  LResponse := nil;

  TaskRequestCompleted := TTask.Create (procedure ()
  var x, i: integer;
  begin

    FResponsedata := TMemoryStream.Create;
    FResponsedata.Position := 0;
    Try
      //FResponseData.Clear;
      //FResponseData.write( AResponse.ContentStream, LSize );
      FResponseData.CopyFrom(AResponse.ContentStream, 0);

      //If we've downloaded a new manager, delete any old backups and create a new one
      If downloadedfilename = 'RSSCT.exe' then
      begin
        DeleteFile('RSSCT.bak');
        RenameFile('RSSCT.exe', 'RSSCT.bak');
      end;

      FResponseData.SaveToFile(downloadedfilename);                       //UNCOMMENT THIS WHEN DONE TESTING<<<---------------------------------
      ReceivingData:= false;
      CheckForUpdatesButton.Enabled := true;
      DataReceived := true;

      //If we've downloaded a new ACM, install
      If downloadedfilename = 'AutogenConfigurationMerger.exe' then
      TThread.Synchronize(nil,
            procedure
            begin
            ACMButtonClick(nil);
            end);

      //if we've downloaded version files we are about to compare version numbers
      If Compare then
      begin
        //Memo1.Lines.Add('Latest versions: '+AResponse.contentasstring);


//        If FileExists('version.ini') then
//        begin
            //get the current managers version from its file info
            currentManager := GetAppVersionInt(ParamStr(0));
            For i in InstalledProducts do
            begin
              If sim = 'xp11' then
                c:= StringReplace(RegQueryStringValue(HKEY_LOCAL_MACHINE, 'SOFTWARE\Richer Simulations\'+RSXPProducts[i], 'Version'),'.','',[rfReplaceAll])
              else
                c:= StringReplace(RegQueryStringValue(HKEY_LOCAL_MACHINE, 'SOFTWARE\Richer Simulations\'+RSProducts[i], 'Version'),'.','',[rfReplaceAll]);
              If c<>'' then
                TAppender<Integer>.Append(CurrentPatch, StrToInt(c));
            end;

            //get all the current version numbers of installed products
//            For i in InstalledProducts do
//            begin
//              c:= ReturnStringBetween('['+RSProducts[i]+']'+sLineBreak+'patchversion=', sLineBreak, 'version.ini');
//              If c<>'' then
//                TAppender<Integer>.Append(CurrentPatch, StrToInt(c));
//            end;

//        end;

        //get the new manager version from the downloaded file
        n:= ReturnStringBetween('managerversion=', sLineBreak, 'newversion.ini');
        If n<>'' then
          newManager := StrToInt(n);

        //get the URL of the new manager
        managerURL:= ReturnStringBetween('managerurl=', sLineBreak, 'newversion.ini');

        For i in InstalledProducts do
        begin
          //get the new patch versions from the downloaded file
          If sim = 'xp11' then
            n:= ReturnStringBetween('['+RSXPProducts[i]+']'+sLineBreak+'patchversion=', sLineBreak, 'newversion.ini')
          else
            n:= ReturnStringBetween('['+RSProducts[i]+']'+sLineBreak+'patchversion=', sLineBreak, 'newversion.ini');
          If n<>'' then
            TAppender<Integer>.Append(newPatch, StrToInt(n));

          //get the URLS of new patches from the downloaded file
          PatchURLs[i]:=ReturnStringBetween('['+RSProducts[i]+']'+sLineBreak+'patchversion='+n+SLineBreak+'patchurl=', sLineBreak, 'newversion.ini');

        end;


      //Compare version numbers
        If newManager>currentManager then
        begin
          URL := managerURL;
          downloadedfilename := FileNameFromURL(URL);
          Download(URL);
        end
        else
        begin
          x:= 0;
          For i in InstalledProducts do
          begin
            If newPatch[x]>currentPatch[x] then
            begin
              With InfoImages[i] do               //???check to ensure that this executes even when CheckForUpdates runs before the images are visible???
              begin
                {Picture.LoadFromFile('Images/Update.png');}
                LoadImageResource(InfoImages[i], HInstance, 'Update');      //show the update notification
                Cursor := crHandPoint;
                Hint := 'Update';
                Enabled := true;
              end;
              UpdateLabels[i].caption := VersionIntToStr(newPatch[x]); //place the version number of the patch on screen
            end;
            inc(x);
          end;
        end;

        Compare := false;

      end
      else
      begin

        If downloadedfilename = 'RSSCT.exe' then
        begin
          Install('manager', 'RSSCT.exe', '');
        end
        else
        begin
          If ContainsText(downloadedfilename, 'patch') then
            Install('patch', downloadedfilename, PatchingProduct)
          else
            Install('', downloadedfilename, PatchingProduct);
        end;

      end;

      //Memo1.Lines.Add('ReceivingData = false;');
    Finally
      FResponseData.Free;
    end;

  End);
  TaskRequestCompleted.Start;

 end;

