    SL: TStringList;
    s,x,y,z: integer;
begin

  try
    //delete addonxml
    DeleteFile(AddonXML);

    //delete entries from scenery.cfg
    SL := TStringList.Create;
    Try
      If FileExists(sceneryCFGPath+'scenery.cfg') then
      begin
        SL.LoadFromFile(sceneryCFGPath+'scenery.cfg');

        For product in RSproducts do
        begin
          For x := 1 to SL.Count-1 do
          begin
            If SL.Strings[x].Contains('Title='+product) then
            begin
              y := x-1;
              z := x+4;
              For s := y to z do
