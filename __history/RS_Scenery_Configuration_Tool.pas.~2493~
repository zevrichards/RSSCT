              try
                aProgressForm.caption := 'Setting LODs';
                aProgressBar.max := Length(ObjArray);
                aProgressForm.Show;
                For obj in ObjArray do
                begin
                  aProgressBar.Position := aProgressBar.Position+1;
                  SL.LoadFromFile(TBPBInstallLocation_XP+'objects\grass\'+obj+'.obj');
                  If ContainsText(obj, '5_') then
                    SL.Strings[SL.Count-2] := 'ATTR_LOD 0.0 ' + IntToStr(TBPBGrassLoadDistanceTrackBar.Position*100+300);    //700m minimum
                  If ContainsText(obj, '4_') then
                    SL.Strings[SL.Count-2] := 'ATTR_LOD 0.0 ' + IntToStr(TBPBGrassLoadDistanceTrackBar.Position*100+300);    //700m minimum
                  If ContainsText(obj, '2_') then
                    SL.Strings[SL.Count-2] := 'ATTR_LOD 0.0 ' + IntToStr(TBPBGrassLoadDistanceTrackBar.Position*100-50);     //350m minimum
