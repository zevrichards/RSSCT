procedure TMainForm.ToggleTBPBDLImages(visible: boolean);
var ImageList: TList<TImage>;
    DynamicLightList: TList<string>;
    i: integer;
    TmpImage: TImage;
begin
  //Reset ImageList and Add TBPB Apron Light Image Components
  ImageList := TList<TImage>.Create;
  DynamicLightList := TList<string>.Create;

  try
    for i := 1 to 21 do
    begin
      //Build the List of 21 TBPB Dynamic Lights
      DynamicLightList.Add('TBPB_Dynamic_Light_'+IntToStr(i));

      //Build the List of 21 Dynamic Light Images
      TmpImage := FindComponent('TBPBDLImage' + IntToStr(i)) as TImage;
      if TmpImage <> nil then      // We found it
        ImageList.Add(TmpImage);
    end;

    //Do the actual toggle of images
    ToggleSODELightImages(ImageList, DynamicLightList, GetEnvironmentVariable('ProgramData')+'\12bPilot\SODE\xml\RS_TBPB_DL.xml', visible);
  finally
    ImageList.Free;
    DynamicLightList.Free;
  end;
end;

procedure TMainForm.ToggleBGLLightImages(ImageArray: TList<TImage>; BGL: String; visible: boolean);
Var AnImage: TImage;
    x: integer;
begin

  x := 0;
  //For the total number of Light Images
  For AnImage in ImageArray do
  begin
    If visible then
    begin
      AnImage.visible := true;
      //load light image based on which ones are currently enabled
      If ((FileExists(BGL+IntToStr(x+1)+'.bgl')) or (FileExists(BGL+'0'+IntToStr(x+1)+'.bgl'))) then
        {AnImage.picture.LoadFromFile('Images/apronlight.png')}
        LoadImageResource(AnImage, HInstance, 'apronlight')
      else
        AnImage.Picture := nil;
    end
    else
      //make invisible
      AnImage.visible := false;
    //next Light Image
    inc(x);
  end;
end;

procedure TMainForm.ToggleSODELightImages(ImageArray: TList<TImage>; DynamicLightList: TList<string>; SODEXML: String; visible: boolean);
Var AnImage: TImage;
    x,y: integer;
    SL: TStringList;
begin

  x := 0;
  //For the total number of Light Images

  For AnImage in ImageArray do
  begin
    If (not visible) or (not FileExists(SODEXML)) then
      //make invisible
      AnImage.visible := false
    else
    begin
      AnImage.visible := true;

      //load light image based on which ones are Defaulted on in XML (Character after 'VisibleOnLoad="' is a 'Y')
      SL := TStringList.Create;
      try
        If FileExists(SODEXML) then
        begin
          SL.LoadFromFile(SODEXML);
          //search to Dynamic List Name
          y := pos(DynamicLightList[x],SL.Text);
          //search forward to VisibleOnLoad="
          y := pos('VisibleOnLoad="',SL.Text,y)+length('VisibleOnLoad="');
          If SL.Text[y] = 'Y' then
            {AnImage.picture.LoadFromFile('Images/apronlight.png')}
            LoadImageResource(AnImage, HInstance, 'apronlight')
          else
            AnImage.Picture := nil;
        end;
      finally
        SL.Free;
      end;

    end;
    //next Light Image
    inc(x);
  end;
end;

