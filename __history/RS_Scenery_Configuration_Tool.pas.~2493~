procedure TMainForm.ToggleSVDDLImages(visible: boolean);
Var ImageList: TList<TImage>;
    BGL: string;
    i: integer;
    TmpImage: TImage;
begin

  //Reset ImageList and Add SVD Dynamic Light Image Components
  ImageList := TList<TImage>.Create;
  BGL := SVDInstallLocation+'scenery\TVSA_dynamic_light_';
  try
    for i := 1 to 7 do
    begin
      TmpImage := FindComponent('DLImage' + IntToStr(i)) as TImage;
      if TmpImage <> nil then      // We found it
        ImageList.Add(TmpImage);
    end;

    ToggleBGLLightImages(ImageList, BGL, visible);
  finally
    ImageList.Free;
  end;

  //to reposition drawn images - - No longer used
  //FormResize(Self);

end;

