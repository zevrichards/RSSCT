            ShowMessage('Fix applied');
          end;
          except
           MessageDlg('Fix could not be applied', mtWarning, [mbOK], 0);
          end;
        end
        else
        begin
          try
          begin
            //determine whether a backup is present
            {If FindFirst(BGIInstallLocation+'texture\MK originals\*.agn',faAnyFile,Rslt)=0  then
            begin}
              //delete our altered files
              DeleteFile(MKTBPBPath+'scenery\8_tpbpv2_photo_RS_seasonal.bgl');
              DeleteFile(MKTBPBPath+'scenery\TBPB_ADEP3_RS.bgl');
