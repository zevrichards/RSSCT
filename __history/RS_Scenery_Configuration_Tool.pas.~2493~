procedure TMainForm.Vincent2019Show(Sender: TObject);
var stat: string;
    x : integer;
begin

  StarReview := RSProducts[4];
  StarPanel.Visible := true;

  If isLegacySim(sim) then
  begin
    //Remove Very Dense Grass from options. There is hardly any difference, and even more VAS usage in FSX
    VincentGrassComboBox.Items.Delete(4);
    //Also disable Dynamic Lighting
    VincentDynamicLightsToggleSwitch.visible := false;
    //Check the file format of one of our BGLs. Enabling patching for legacy sims if the file format is P3Dv2 or higher
    SVDLegacyPatchButton.Visible := true;
