              RenameFile(MKTBPBPath+'scenery\14_tpbpv2_lines.off',MKTBPBPath+'scenery\14_tpbpv2_lines.bgl');
              RenameFile(MKTBPBPath+'scenery\applights.off',MKTBPBPath+'scenery\applights.bgl');
