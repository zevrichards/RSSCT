procedure TMainForm.CheckForTimeOut;
var TimeSince: Integer;
begin
  TimeSince := 0;
  While ((TimeSince < NetHTTPRequest.ConnectionTimeout) and (ReceivingData = false)) do
    TimeSince := TThread.GetTickCount - FGlobalStart;
  If TimeSince >= NetHTTPRequest.ConnectionTimeout then
  begin
    TThread.Synchronize(nil,
            procedure
            begin
            GifChange(false);
            Memo1.Lines.Add('Connection Timed Out');
            end);
  end;
end;

