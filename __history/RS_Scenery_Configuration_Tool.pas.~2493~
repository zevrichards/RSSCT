procedure TMainForm.LegacyPatchButtonsEnable(Product: TSODEProduct);
var f: integer;
begin

  If TArray.BinarySearch<integer>(InstalledProducts, product.Index, f) then
  begin
    Product.LegacyPatchButton.Caption := 'Patch Scenery for ' + AnsiUpperCase(sim);
    Product.LegacyPatchButton.visible := false;
    If FileExists(Product.PatchFile) then
    begin
      If CheckMDLFileFormat(Product.PatchFile, 'MDLXMDL') = false then
      begin
        If MyMessageDialog(Product.name+' is installed but is not patched for '+AnsiUpperCase(sim)+'. Would you like to patch it now?', mtInformation, mbOKCancel, ['Now', 'Later']) = mrOK then
          Product.LegacyPatchButton.Click;
      end;
    end;
  end;

end;

procedure TMainForm.SODEFileCheck(Product: TSODEProduct);
var f: integer;
    SL: TStringList;
    FallbackLocation: string;
begin
  If InstalledProducts <> nil then
  begin
    If TArray.BinarySearch<integer>(InstalledProducts, product.Index, f) then
    begin
      //copy product SODE files
      If not FileExists(product.SODEXML) then
      begin
        If System.SysUtils.DirectoryExists(product.InstallLocation+'SODE') then
          TDirectory.Copy(product.InstallLocation+'SODE', GetEnvironmentVariable('ProgramData')+'\12bPilot\SODE\');
      end;

      SL:= TStringList.Create;
      try
        If FileExists(product.TextureCFG) then
        begin
          SL.LoadFromFile(product.TextureCFG);
          If pos('RS Common\Texture', SL.Text) = 0 then    //not found
            SL.Text := SL.Text + 'fallback.'+IntToStr(SL.Count)+'='+RSCommonInstallLocation+'Texture'  //add the fallback
          else  //found
          begin
            FallbackLocation := ReturnStringBetween('fallback.3=', sLineBreak, product.TextureCFG);  //extract the location
            If not System.SysUtils.DirectoryExists(FallbackLocation) then    //verify that location is correct
              SL.Text:= StringReplace(SL.Text, FallbackLocation, RSCommonInstallLocation+'Texture',[]);    //if not correct it
          end;
          SL.SaveToFile(product.TextureCFG);
        end;
      finally
        SL.Free;
      end;

    end;
  end;
end;

procedure TMainForm.DynamicLightSwitch(DLImage: TImage; AnSODEProduct: TSODEProduct; AnApronLightsToggleSwitch: TToggleSwitch; DynamicLightName, BGLNameNoExt: string);
begin

  With DLImage do
  begin
    If Picture.Graphic <> nil then
    begin
      Picture := nil;
      EditSODELightDefaultState(GetEnvironmentVariable('ProgramData')+'\12bPilot\SODE\xml\RS_TBPB_DL.xml', DynamicLightName, ssOff);
      If AnApronLightsToggleSwitch.State = tssOn then //ssOn means switch BGL on when dynamic light goes off
        RenameFile(AnSODEProduct.InstallLocation+'scenery\'+BGLNameNoExt+'.off',AnSODEProduct.InstallLocation+'scenery\'+BGLNameNoExt+'.bgl');
    end
    else
    begin
      {Picture.LoadFromFile('Images/apronlight.png');}
      LoadImageResource(DLImage, HInstance, 'apronlight');
      EditSODELightDefaultState(GetEnvironmentVariable('ProgramData')+'\12bPilot\SODE\xml\RS_TBPB_DL.xml', DynamicLightName, ssOn);
      If AnApronLightsToggleSwitch.State = tssOn then //ssOn means switch BGL off when dynamic light goes on
        RenameFile(AnSODEProduct.InstallLocation+'scenery\'+BGLNameNoExt+'.bgl',AnSODEProduct.InstallLocation+'scenery\'+BGLNameNoExt+'.off');
    end;
  end;

end;

procedure TMainForm.EditSODELightDefaultState(AnSODEXML, DynamicLightName: string; SwitchState: TSwitchState);
var SL: TStringList;
    x: integer;
    Searchstring: string;
begin

  SL := TStringList.Create;
  try
    If FileExists(AnSODEXML) then
    begin
      //Load the SODE XML containing the dynamic lights
      SL.LoadFromFile(AnSODEXML);

      //Search for the position Dynamic Light we will be swithcing on/off
      SearchString := '"'+DynamicLightName+'"';
      x := pos(SearchString, SL.Text)+ Length(SearchString);
  //    x := ReturnPosXMLEntry(AnSODEXML, SearchString);

      //Search on to the position of the default state
      SearchString := 'VisibleOnLoad="';
      x := pos(SearchString, SL.Text, x)+ Length(SearchString)-1;

      //Replace the first occurence after this position with the opposite state
      If SwitchState = ssOn then
        SL.Text := LeftStr(SL.text,x) + StringReplace(RightStr(SL.text,length(SL.Text)-x), 'No', 'Yes', [rfIgnoreCase])
      else
        SL.Text := LeftStr(SL.text,x) + StringReplace(RightStr(SL.text,length(SL.Text)-x), 'Yes', 'No', [rfIgnoreCase]);

      //Save
      SL.SaveToFile(AnSODEXML);
    end;

  finally
    Sl.Free;
  end;

end;

function TMainForm.SearchForRSCommonEntries(SL: TStringList): TObjectList<TRSCommonEntries>;
var x:integer;
    prefix: string;
    RSCommonEntry: TRSCommonEntries;
    v: string;

begin
  result := TObjectList<TRSCommonEntries>.create;

  For x := 0 to SL.Count-1 do
  begin
    If ContainsText(SL.Strings[x], '\RS Common') then
    begin
      If not ContainsText(SL.Strings[x], 'Autogen') then //ignore paths related to autogen
      begin
        RSCommonEntry := TRSCommonEntries.create;
        With RSCommonEntry do
        begin
          pos := x;  //store location of matches in list
          If ContainsText(SL.Strings[x], 'Local=') then
          begin
            Prefix := 'Local=';
            filename := sceneryCFGPath+'scenery.cfg'; //store path of matches in list
            path := RightStr(trim(SL.Strings[x]), length(trim(SL.Strings[x]))-length(Prefix));
          end
          else
          begin
            Prefix := '<Path>';
            v := sim[High(sim)];
            filename := GetSpecialFolder(CSIDL_PERSONAL)+'Prepar3D v'+v+' Add-ons\Richer Simulations\Add-on.xml'; //store path of matches in list
            If not FileExists(Filename) then //account for different documents folder
              filename := GetSpecialFolder(CSIDL_PROFILE)+'Documents\Prepar3D v'+v+' Add-ons\Richer Simulations\Add-on.xml';
            path := ReturnStringBetweenText('<Path>','</Path>',SL.Strings[x]);
          end;

          datecreated := GetFolderCreationDate(path);
        end;
        result.add(RSCommonEntry)
      end;
    end;
  end;

end;

procedure TMainForm.CheckForRSCommonConflicts;
var SL: TStringList;
    x,y,z: integer;
    RSCommonEntry: TRSCommonEntries;
    RSCommonList: TObjectList<TRSCommonEntries>;
    conflict: boolean;
begin

  conflict := false;

//search scenery.cfg
  RSCommonList := TObjectList<TRSCommonEntries>.create;

  SL := TStringList.Create;
  try
    If FileExists(sceneryCFGPath+'scenery.cfg') then
    begin
      SL.LoadFromFile (sceneryCFGPath+'scenery.cfg');
      RSCommonList := SearchForRSCommonEntries(SL);
    end;
  finally
    SL.Free;
  end;

//search add-on.xml
  If not isLegacySim(sim) then
  begin

    SL := TStringList.Create;
    try
      If FileExists(AddonXML) then
      begin
        SL.LoadFromFile (AddonXML);
        RSCommonList.addrange(SearchForRSCommonEntries(SL));
      end;
    finally
      SL.Free;
    end;

  end;

//compare matches
  If RSCommonList.Count > 1 then begin
    For x := 1 to RSCommonList.Count-1 do
    begin
      If RSCommonList[0].path <> RSCommonList[x].path then
      begin
        conflict := true;   //if paths are different raise flag
        break;
      end
      else
        conflict := false;
    end;
  end;

  If conflict then
  begin
    //return number of entries with different paths
    If MyMessageDialog('There appears to be '+IntToStr(RSCommonList.count)+' RS Common folders on your system which could lead to potential conflicts. Would you like to have the tool try to resolve this?',mtWarning,mbYesNo,['Resolve','Cancel']) = mrYes then
    begin
      //sort list by date
      RSCommonList.Sort(TComparer<TRSCommonEntries>.Construct(
                  function (const L, R: TRSCommonEntries): integer
                  begin
                    Result := CompareDate(L.datecreated, R.datecreated);
                  end
                  ));

      RSCommonList.Reverse;

      //remove entry that we are keeping from list
      RSCommonList.Remove(RSCommonList.First);
      RSCommonList.Capacity := RSCommonList.Count; //free memory and pack list

      //remove remainder from files, deleting paths as removed
      For RSCommonEntry in RSCommonList do
      begin
        SL := TStringList.Create;
        try
          If FileExists(RSCommonEntry.filename) then
          begin
            SL.LoadFromFile(RSCommonEntry.filename);

            //remove lines from cfg/xml
            If ContainsText(RSCommonEntry.filename, 'scenery.cfg') then
            begin
              For x:= 1 to 6 do
                SL.Delete(RSCommonEntry.pos-2);   //6 lines to delete in scenery.cfg starting 2 lines above the RSCommonentry.path
            end
            else
            begin
              y := RSCommonEntry.pos;
              z := RSCommonEntry.pos;

              While not (SL.Strings[y].Contains('<AddOn.Name>') or (y<1)) do   //search backward to begninning of <addOn>
                dec(y);

              While not (SL.Strings[z].Contains('<AddOn.Name>') or (z>SL.Count)) do   //search forward to end of <addOn>
                inc(z);

              For x:= z-1 downto y do
                SL.Delete(x);  //delete from starting index, remember indexes change as we delete
            end;
            SL.SaveToFile(RSCommonEntry.filename);

            //delete folder
            DeleteWithUndo(RSCommonEntry.path+'\');
          end;
        finally
          SL.Free
        end;
      end;
    end;
  end;
  RSCommonList.Free;
end;

