function TMainForm.Install(ToInstall, filename, product: string): boolean;
var
    stat, log: string;
    ReturnCode: integer;
begin
  //Install update/run patch
  result:= false;
  ReturnCode := -1;
  If ToInstall = 'manager' then
  begin
       Memo1.Lines.Add('Installing new configuration manager');
       //delete the old, bring in the new
       DeleteFile('RSSCT.bak');
       RestartThisApp;
  end
  else
  begin
     Memo1.Lines.Add('Running file...');
     //THIS NEED TO BE WAITING! In order to run LegacyCopy afterwards!
     ReturnCode := RunProgramWaiting(filename,'', [''], log);
     If ReturnCode = 0 then
     begin
       Memo1.Lines.Add(filename+' run.');
       stat := stat+filename+' run.';
       LogUpdate(stat, 'RSSCT.log');
       If VerboseLoggingCheckbox.Checked then
        LogUpdate(stat, 'RSSCT_verbose.log');
       result := true;

       //copy any new files which may have been installed to the installed to the richersims effects, textures and world folders over to the legacy sim location if not using p3dv4
       If isLegacySim(sim) then
        LegacyCopy(simpath);

     end
     else
     begin
       MessageDlg('Error occurred! Patch could not be run!', mtError, [mbOK], 0);
       Memo1.Lines.Add(filename+' not run.');
       stat:= stat+filename+' not run.';
       If VerboseLoggingCheckbox.Checked then
        LogUpdate(stat, 'RSSCT_verbose.log');
       LogUpdate(stat, 'RSSCT.log');
       result := false;
     end;
  end;

  If ((ToInstall = 'patch') and (ReturnCode=0)) then
  //purge config folder of patch after succesful install
      DeleteWithUndo(filename);

end;

