                    SL.Strings[SL.Count-2] := 'ATTR_LOD 0.0 ' + IntToStr(TBPBGrassLoadDistanceTrackBar.Position*100-225);    //175m minimum
                  SL.SaveToFile(TBPBInstallLocation_XP+'objects\grass\'+obj+'.obj');
                end;
              finally
                aProgressForm.Close;
                SL.Free;
              end;
            end;

          end
          else
          begin

            If TBPBGrassLoadDistanceTrackBar.Position = 3 then
            begin
              TBPBGrassLoadDistanceLabel.Caption := 'Grass Load Distance: Off';
              TBPBGrassFadeLevelTrackBar.Enabled := false;
              TBPBGrassFadeLevelLabel.Enabled := false;
              RenameFile(GetEnvironmentVariable('ProgramData')+'\12bPilot\SODE\xml\RS_TBPB_Grass.xml', GetEnvironmentVariable('ProgramData')+'\12bPilot\SODE\xml\RS_TBPB_Grass.off');
            end
            else
            begin
              TBPBGrassLoadDistanceLabel.Caption := 'Grass Load Distance: ' + IntToStr(TBPBGrassLoadDistanceTrackBar.Position * 100)+'m';
              TBPBGrassFadeLevelTrackBar.Enabled := true;
              TBPBGrassFadeLevelLabel.Enabled := true;
              If FileExists(GetEnvironmentVariable('ProgramData')+'\12bPilot\SODE\xml\RS_TBPB_Grass.off') then
                RenameFile(GetEnvironmentVariable('ProgramData')+'\12bPilot\SODE\xml\RS_TBPB_Grass.off', GetEnvironmentVariable('ProgramData')+'\12bPilot\SODE\xml\RS_TBPB_Grass.xml');

              LastDistance := '';
              SearchString := 'Proximity,';

              If FileExists(GetEnvironmentVariable('ProgramData')+'\12bPilot\SODE\xml\RS_TBPB_Grass.xml') then
              begin
                SL := TStringList.Create;
                Try
                  SL.LoadFromFile(GetEnvironmentVariable('ProgramData')+'\12bPilot\SODE\xml\RS_TBPB_Grass.xml');
                  x := pos(SearchString,SL.Text)+length(SearchString);
                  While SL.Text[x] <> ' ' do
                  begin
                    If SL.Text[x] <> '"' then
                      LastDistance := trim(LastDistance + SL.Text[x]);
                    inc(x);
                  end;
                  SL.Text := StringReplace(SL.text,'Proximity,'+LastDistance,'Proximity,'+IntToStr(TBPBGrassLoadDistanceTrackBar.Position * 100),[rfReplaceAll]);
                  SL.SaveToFile(GetEnvironmentVariable('ProgramData')+'\12bPilot\SODE\xml\RS_TBPB_Grass.xml');
                finally
                  SL.Free;
                end;
              end;
            end;

          End;

        Finally
          TBPBGrassDistanceTrackBarLastPosition := TBPBGrassLoadDistanceTrackBar.Position;
        End;
    end;
  end;

//end;

