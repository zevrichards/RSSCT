procedure TMainForm.TBPBCompatibilityToggleSwitchClick(Sender: TObject);
var Rslt : TSearchRec;
begin
    If TBPBCompatibilityToggleSwitch.state = tssON then
      begin
      try
          begin
            //remove the originals, theyre already backed up
            if FindFirst(MKTBPBPath+'texture\*x*.bmp',faAnyFile,Rslt) = 0 then   //0 when found
            begin
              try
                repeat
                  If not ((Rslt.Name = 'concexp.bmp') or (Rslt.Name = 'concexp_lm.bmp')) then    //comparison to string 'concexp.bmp' and 'concexp_lm.bmp' does not work for some reason, so ive used there rawbyte equivalent since we dont want to delete these 2 files
                     DeleteFile(MKTBPBPath+'texture\'+Rslt.Name);
                until FindNext(Rslt) <> 0;
              finally
                FindClose(Rslt);  // Free resources on successful find
              end;
            end;
            //copy altered DDS and BGLs over
            CopyFiles(BGIInstallLocation+'MK TBPB V2 Fix\*.dds', MKTBPBPath+'texture\', FOF_NOCONFIRMATION);
            CopyFiles(BGIInstallLocation+'MK TBPB V2 Fix\*.bgl', MKTBPBPath+'scenery\', FOF_NOCONFIRMATION);
            //rename originals to .off
            RenameFile(MKTBPBPath+'scenery\8_tpbpv2_photo.bgl',MKTBPBPath+'scenery\8_tpbpv2_photo.off');
            RenameFile(MKTBPBPath+'scenery\TBPB_ADEX_XX_CVX.bgl',MKTBPBPath+'scenery\TBPB_ADEX_XX_CVX.off');
            RenameFile(MKTBPBPath+'scenery\12_tpbpv2_dirt.bgl',MKTBPBPath+'scenery\12_tpbpv2_dirt.off');
            RenameFile(MKTBPBPath+'scenery\14_tpbpv2_lines.bgl',MKTBPBPath+'scenery\14_tpbpv2_lines.off');
