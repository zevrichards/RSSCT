              DeleteFile(MKTBPBPath+'scenery\tbpbx_trees_rs.bgl');
              DeleteFile(MKTBPBPath+'scenery\12_tpbpv2_dirt_rs.bgl');
              DeleteFile(MKTBPBPath+'scenery\14_tpbpv2_lines_rs.bgl');
