procedure TMainForm.TBPB2020Show(Sender: TObject);
var GrassXML, stat: string;
    x: integer;
    BckEvent: TNotifyEvent;
begin

  StarReview := RSProducts[7];
  StarPanel.Visible := true;

  If isLegacySim(sim) then
  begin
    TBPBDynamicLightsToggleSwitch.Visible := false;
    TBPBApronLightsToggleSwitch.Visible := false;

    //Check the file format of one of our BGLs. Enabling patching for legacy sims if the file format is P3Dv2 or higher
    TBPBLegacyPatchButton.Visible := true;
    TBPBLegacyPatchButton.Caption := 'Patch for '+AnsiUpperCase(sim);
    If FileExists(SODEProductArray[1].patchfile) then
      TBPBLegacyPatchButton.Enabled:= CheckMDLFileFormat(SODEProductArray[1].patchfile, 'PV20MDL');
  end;

  //initialize component states based on corresponding file states and sim
  If sim = 'xp11' then
  begin

    TBPBDynamicLightsToggleSwitch.Visible := false;
    TBPBApronLightsToggleSwitch.Visible := false;
    TBPBLegacyPatchButton.Visible := false;
    TBPBGrassFadeLevelTrackBar.Visible := false;
    TBPBGrassFadeLevelLabel.Visible := false;

    //Parking Lot
    If ReturnStringBetween('ATTR_LOD ', sLineBreak, TBPBInstallLocation_XP+'objects\TBPB_main_1-tbpb_parking_lot.obj') = '0.0 3000.0' then
      TBPBParkingLotToggleSwitch.State := tsson
    else
      TBPBParkingLotToggleSwitch.State := tssoff;

    //3D Grass
    BckEvent :=  TBPBGrassLoadDistanceTrackbar.OnChange;   //temp removal of onchange event
    TBPBGrassLoadDistanceTrackbar.OnChange := nil;

    TryStrToInt(ReturnStringBetween('ATTR_LOD 0.0 ', sLineBreak, TBPBInstallLocation_XP+'objects\grass\5_00.obj'),x);
    If x <> 0 then
    begin
      TBPBGrassLoadDistanceTrackbar.Position := round((x-300)/100);
      TBPBGrassFadeLevelTrackBar.Enabled := true;
      TBPBGrassLoadDistanceLabel.Caption := 'Grass Load Distance: ' + IntToStr(TBPBGrassLoadDistanceTrackBar.Position * 100)+'m';
    end
    else
    begin
      TBPBGrassLoadDistanceTrackBar.Position := 3;
      TBPBGrassFadeLevelTrackBar.Enabled := false;
      TBPBGrassLoadDistanceLabel.Caption := 'Grass Load Distance: off';
    end;

    TBPBGrassLoadDistanceTrackbar.OnChange := BckEvent;

    //High Poly Veg
    If ReturnStringBetween('ATTR_LOD ', sLineBreak, TBPBInstallLocation_XP+'objects\TBPB_vegetation_front-all_mid_polys_0.obj') = '0.0 3000.0' then
      TBPBVegComboBox.ItemIndex := 3
    else
    begin
      If ReturnStringBetween('ATTR_LOD ', sLineBreak, TBPBInstallLocation_XP+'objects\TBPB_vegetation_sides-all_mid_polys_0.obj') = '0.0 3000.0'  then
      TBPBVegComboBox.ItemIndex := 2
      else
      begin
        If ReturnStringBetween('ATTR_LOD ', sLineBreak, TBPBInstallLocation_XP+'objects\TBPB_vegetation_back_1-all_mid_polys_0.obj') = '0.0 3000.0'  then
          TBPBVegComboBox.ItemIndex := 1
        else
          TBPBVegComboBox.ItemIndex := 0;
      end;
    end;

  end
  else
  begin

    //Dynamic Lights
    If FileExists(GetEnvironmentVariable('ProgramData')+'\12bPilot\SODE\xml\RS_TBPB_DL.xml') then
      TBPBDynamicLightsToggleSwitch.state := tssOn
    else
      TBPBDynamicLightsToggleSwitch.state := tssOff;

    //Parking Lot
    If FileExists(TBPBInstallLocation+'scenery\TBPB_parking_lot_vehicles_1.bgl') then
      TBPBParkingLotToggleSwitch.State := tsson
    else
      TBPBParkingLotToggleSwitch.State := tssoff;

    //3D Grass
    GrassXML := StringReplace(SODEProductArray[1].SODEXML, 'TBPB', 'TBPB_grass', []);
    If FileExists(GrassXML) then
    begin
      If TryStrToInt(ReturnStringBetween('Proximity,','"', GrassXML),x) then
      begin
        TBPBGrassLoadDistanceTrackbar.Position := round(x/100);
        TBPBGrassLoadDistanceLabel.Caption := 'Grass Load Distance: ' + IntToStr(TBPBGrassLoadDistanceTrackBar.Position * 100)+'m';
      end;
      TBPBGrassFadeLevelTrackBar.Enabled := true;
    end
    else
    begin
      TBPBGrassLoadDistanceTrackBar.Position := 3;
      TBPBGrassFadeLevelTrackBar.Enabled := false;
      TBPBGrassLoadDistanceLabel.Caption := 'Grass Load Distance: off';
    end;

    //High Poly Veg
    If FileExists(TBPBInstallLocation+'scenery\TBPB_vegetation_back_1.bgl') then
      TBPBVegComboBox.ItemIndex := 3
    else
    begin
      If FileExists(TBPBInstallLocation+'scenery\TBPB_vegetation_sides.bgl') then
      TBPBVegComboBox.ItemIndex := 2
      else
      begin
        If FileExists(TBPBInstallLocation+'scenery\TBPB_vegetation_front.bgl') then
          TBPBVegComboBox.ItemIndex := 1
        else
          TBPBVegComboBox.ItemIndex := 0;
      end;
    end;

  end;

  stat := sLineBreak+'[TBPB]'+sLineBreak+'TBPBDynamicLightsToggleSwitch='+BoolToString(TBPBDynamicLightsToggleSwitch.IsOn)
          + sLineBreak+ 'TBPBParkingLotToggleSwitch='+BoolToString(TBPBParkingLotToggleSwitch.IsOn)
          + sLineBreak+ 'RS_TBPB_Grass.xml='+IntToStr(x)+'m'
          + sLineBreak+ 'TBPBVegComboBox='+IntToStr(TBPBVegComboBox.ItemIndex);

  If VerboseLoggingCheckbox.checked then
    LogUpdate(stat,'RSSCT_Verbose.log');

  //Trackbar variable initialization to prevent triple trigger of OnChange Event
  TBPBGrassDistanceTrackBarLastPosition := TBPBGrassLoadDistanceTrackBar.Position;
  TBPBGrassFadeTrackBarLastPosition := TBPBGrassFadeLevelTrackBar.Position;

end;

