function TMainForm.FileNameFromURL(URL:String):String;
var x,y: integer;
begin
  y := high(URL);
      while URL[y] <> '/' do
        y := y-1;

      for x := y+1 to high(URL) do
        result:= result + trim(URL[x]);

      //handle %20 spaces and ends of dropbox links in the filename
      result := StringReplace(result, '?dl=1', '',[rfReplaceAll]);
      result := StringReplace(result, '%20', ' ',[rfReplaceAll]);
end;


procedure TMainForm.FixMissingLightsCheckBoxClick(Sender: TObject);
var
    simcfg, searchstring: string;
    y: integer;
begin


    If ContainsText(sim,'FSX') then
     simcfg := 'FSX.cfg'
    else
     simcfg := 'Prepar3d.cfg';

    If FileExists(LWCFGPath+simcfg) then
    begin
      If FixMissingLightsCheckBox.Checked = true then
      begin
        BuildingsPerCell.Caption := ReturnStringBetween('TERRAIN_MAX_AUTOGEN_BUILDINGS_PER_CELL=', sLineBreak, LWCFGPath+simcfg);

        SearchString := 'TERRAIN_MAX_AUTOGEN_BUILDINGS_PER_CELL=';
        y := ReturnPosXMLEntry(LWCFGPath+simcfg, SearchString);

        If y <= length(SearchString) then //if not found set to 5000
          ReplaceXMLEntry(LWCFGPath+simcfg,'[TERRAIN]','[TERRAIN]'#13#10'TERRAIN_MAX_AUTOGEN_BUILDINGS_PER_CELL=5000')
        else
         begin
           If (BuildingsPerCell.Caption<>'') and (StrToInt(trim(BuildingsPerCell.Caption)) < 5000) then   //if found and less than 5000 set it to 5000
             ReplaceXMLEntry(LWCFGPath+simcfg,'TERRAIN_MAX_AUTOGEN_BUILDINGS_PER_CELL='+BuildingsPerCell.caption,'TERRAIN_MAX_AUTOGEN_BUILDINGS_PER_CELL=5000');
         end;

      end
      else
      //else we are removing the fix and...
      begin

        If BuildingsPerCell.Caption <> '' then     //...replacing with the original value.
          ReplaceXMLEntry(LWCFGPath+simcfg,'TERRAIN_MAX_AUTOGEN_BUILDINGS_PER_CELL=5000','TERRAIN_MAX_AUTOGEN_BUILDINGS_PER_CELL='+BuildingsPerCell.caption)
        else  //..or just removing it all together if there was no original value.
          ReplaceXMLEntry(LWCFGPath+simcfg,#13#10'TERRAIN_MAX_AUTOGEN_BUILDINGS_PER_CELL=5000','');

      end;
    end
    else
      MessageDlg(simcfg+' not found!',mtError,[mbOK],0);


end;

