    If FileExists(SODEProductArray[0].patchfile) then
      SVDLegacyPatchButton.Enabled:= CheckMDLFileFormat(SODEProductArray[0].patchfile, 'PV20MDL');
  end;

   //initialize component states based on corresponding file states
  If sim = 'xp11' then
  begin

    VincentDynamicLightsToggleSwitch.Visible := false;
    VincentApronShadowsToggleSwitch.Visible := false;
    SVDLegacyPatchButton.Visible := false;

    {
    //Parking Lot
    If ReturnStringBetween('ATTR_LOD ', sLineBreak, SVDInstallLocation_XP+' .obj') = '0.0 3000.0' then
      VincentParkingLotToggleSwitch.State := tsson
    else
      VincentParkingLotToggleSwitch.State := tssoff;

    //3D Grass
    If ReturnStringBetween('ATTR_LOD ', sLineBreak, SVDInstallLocation_XP+' .obj') = '0.0 3000.0' then
      VincentGrassComboBox.ItemIndex := 4
    else
    begin
      If ReturnStringBetween('ATTR_LOD ', sLineBreak, SVDInstallLocation_XP+' .obj') = '0.0 3000.0' then
        VincentGrassComboBox.ItemIndex := 3
      else
      begin
        If ReturnStringBetween('ATTR_LOD ', sLineBreak, SVDInstallLocation_XP+' .obj') = '0.0 3000.0' then
        VincentGrassComboBox.ItemIndex := 2
        else
        begin
          If ReturnStringBetween('ATTR_LOD ', sLineBreak, SVDInstallLocation_XP+' .obj') = '0.0 3000.0' then
            VincentGrassComboBox.ItemIndex := 1
          else
            VincentGrassComboBox.ItemIndex := 0;
        end;
      end;
    end;

    //High Poly Veg
    If ReturnStringBetween('ATTR_LOD ', sLineBreak, SVDInstallLocation_XP+' .obj') = '0.0 3000.0' then
      HighPolyVegToggleSwitch.State := tsson
    else
      HighPolyVegToggleSwitch.State := tssoff;


    //Terminal Interior
    If ReturnStringBetween('ATTR_LOD ', sLineBreak, SVDInstallLocation_XP+' .obj') = '0.0 3000.0' then
      InteriorToggleSwitch.State := tsson
    else
      InteriorToggleSwitch.State := tssoff;  }

  end
  else   //fsx/p3d
  begin

    //Apron Lights
    If FileExists(SVDInstallLocation+'scenery\TVSA_GP_LM.bgl') then
      VincentApronShadowsToggleSwitch.state := tssOn
    else
      VincentApronShadowsToggleSwitch.state := tssOff;

    //Parking Lot
    If FileExists(SVDInstallLocation+'scenery\TVSA_parking_lot.bgl') then
      VincentParkingLotToggleSwitch.State := tsson
    else
      VincentParkingLotToggleSwitch.State := tssoff;

    //3D Grass
    If FileExists(SVDInstallLocation+'scenery\TVSA_Grass_4.bgl') then
      VincentGrassComboBox.ItemIndex := 4
    else
    begin
      If FileExists(SVDInstallLocation+'scenery\TVSA_Grass_3.bgl') then
        VincentGrassComboBox.ItemIndex := 3
      else
      begin
        If FileExists(SVDInstallLocation+'scenery\TVSA_Grass_2.bgl') then
        VincentGrassComboBox.ItemIndex := 2
        else
        begin
          If FileExists(SVDInstallLocation+'scenery\TVSA_Grass_1.bgl') then
            VincentGrassComboBox.ItemIndex := 1
          else
            VincentGrassComboBox.ItemIndex := 0;
        end;
      end;
    end;

    //High Poly Veg
    If FileExists(SVDInstallLocation+'scenery\TVSA_front_veg.bgl') then
      HighPolyVegToggleSwitch.State := tsson
    else
      HighPolyVegToggleSwitch.State := tssoff;


    //Terminal Interior
    If FileExists(SVDInstallLocation+'scenery\TVSA_interior.bgl') then
      InteriorToggleSwitch.State := tsson
    else
      InteriorToggleSwitch.State := tssoff;

  end;

  stat := sLineBreak+'[TVSA]'+sLineBreak+'VincentApronShadowsToggleSwitch='+BoolToString(VincentApronShadowsToggleSwitch.IsOn)
          + sLineBreak+ 'VincentParkingLotToggleSwitch='+BoolToString(VincentParkingLotToggleSwitch.IsOn)
          + sLineBreak+ 'VincentGrassComboBox='+IntToStr(VincentGrassComboBox.ItemIndex)
          + sLineBreak+ 'HighPolyVegToggleSwitch='+BoolToString(HighPolyVegToggleSwitch.IsOn)
          + sLineBreak+ 'InteriorToggleSwitch='+BoolToString(InteriorToggleSwitch.IsOn);

  stat := stat + sLineBreak+ 'DynamicLights=';
  For x := 1 to 7 do
  begin
    If FileExists(SVDInstallLocation+'scenery\TVSA_dynamic_light_'+IntToStr(x)+'.bgl') then
      stat := stat + IntToStr(x)+','
  end;

  If VerboseLoggingCheckbox.checked then
