              RenameFile(MKTBPBPath+'scenery\pointlights.off',MKTBPBPath+'scenery\pointlights.bgl');
              RenameFile(MKTBPBPath+'scenery\tbpbx_trees.off',MKTBPBPath+'scenery\tbpbx_trees.bgl');
