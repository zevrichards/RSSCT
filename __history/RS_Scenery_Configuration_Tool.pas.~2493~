//change trackbar scroll events to not fire Onchange until the scroll is stopped
procedure TTrackBar.CNHScroll(var Message: TWMHScroll);
begin
  if Message.ScrollCode = 5 then             //TB_THUMBTRACK = 5
    Message.Result := 0
  else
    inherited;
end;

//similar code @ http://edn.embarcadero.com/de/article/23057
procedure TMainForm.BeforeDestruction;
var i: integer;
    Comps: Array of TComponent;

begin
  inherited;

  SetLength(Comps, ComponentCount);
  For i := 0 to ComponentCount-1 do
  begin
    Comps[i]:= Components[i];
  end;

  SaveState(Comps, ComponentCount, ExtractFilePath(Application.ExeName)+'RSSCT.fs')

end;

procedure TMainForm.SetGlobalVariables(simulator: string; simindex: integer);
var SODEproduct: TSODEProduct;
    v, stat: string;
begin
  MainForm.Caption := MainForm.Caption+' v'+GetAppVersionStr(ParamStr(0))+' '+AnsiUpperCase(simulator);

  v := simulator[High(simulator)];
  AddonXML:= GetSpecialFolder(CSIDL_PERSONAL)+'Prepar3D v'+v+' Add-ons\Richer Simulations\Add-on.xml';
  If not System.SysUtils.DirectoryExists(GetSpecialFolder(CSIDL_PERSONAL)+'Prepar3D v'+v+' Add-ons\') then //account for different documents folder
    AddonXML := GetSpecialFolder(CSIDL_PROFILE)+'Documents\Prepar3D v'+v+' Add-ons\Richer Simulations\Add-on.xml';

  sim := simulator;
  Simpath := GetSimPath(simkeys64[simindex], simkeys32[simindex]);
  If ContainsText(sim, 'xp11') then
  begin
    sceneryCFGpath := Simpath+'Custom Scenery\';
    LWCFGpath:='';
  end
  else
  begin
    sceneryCFGpath:= ProgramDataPaths[simindex];
    LWCFGpath:=AppDataPaths[simindex];
  end;

  InstalledProducts:= DetectInstalledProducts(SimPath, AddonXML, sceneryCFGPath, sim, UseP3DAutogenSystemBtn.Checked);


  If ContainsText(sim, 'xp11') then
  begin

    RSCommonInstallLocation_XP := FindInstallLocation('RS_Common', sceneryCFGpath, simpath, sim);
    BGIInstallLocation_XP := FindInstallLocation('RS_Barbados_2017', sceneryCFGpath, simpath, sim);
    SVDInstallLocation_XP := FindInstallLocation('RS_St_Vincent_2019', sceneryCFGpath, simpath, sim);
    TBPBInstallLocation_XP := FindInstallLocation('RS_TBPB_2020', sceneryCFGpath, simpath, sim);

  end
  else
  begin

    RSCommonInstallLocation := FindInstallLocation('RS Common', sceneryCFGpath, simpath, sim);
    //GNDInstallLocation := FindInstallLocation('RS Grenada 2020', sceneryCFGpath, simpath, sim);
    SKNInstallLocation := FindInstallLocation('RS St Kitts 2017', sceneryCFGpath, simpath, sim);
    T2GTKPKPath := FindInstallLocation('TKPK-TERRAIN', sceneryCFGpath, simpath, sim);
    BGIInstallLocation := FindInstallLocation('RS Barbados 2017', sceneryCFGpath, simpath, sim);
    MKTBPBPath := FindInstallLocation('TBPB FSX v2', sceneryCFGPath, simpath, sim);
    ANUInstallLocation := FindInstallLocation('RS Antigua 2018', sceneryCFGpath, simpath, sim);
    TSTAPAPath := FindInstallLocation('TAPA2017', sceneryCFGpath, simpath, sim);
    SVDInstallLocation := FindInstallLocation('RS St Vincent 2019', sceneryCFGpath, simpath, sim);
    TSTVSVPath := FindInstallLocation('TVSV-TERRAIN', sceneryCFGpath, simpath, sim);
    TBPBInstallLocation := FindInstallLocation('RS TBPB 2020', sceneryCFGpath, simpath, sim);
    //DOMInstallLocation := FindInstallLocation('RS Dominica 2019', sceneryCFGpath, simpath, sim);

  end;

  //Write Install Locations into registry for use by patch installers
  WriteProductLocationToReg(Self.Handle, 'RSSCT' ,Application.ExeName);

  If ContainsText(sim, 'xp11') then
  begin

    If RSCommonInstallLocation_XP<>'' then
      WriteProductLocationToReg(Self.Handle, RSXPProducts[0] ,RSCommonInstallLocation_XP);
    If TBPBInstallLocation_XP<>'' then
