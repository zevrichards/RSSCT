unit EmailFeedback;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls,
  ShellAPI;

type
  TEmailForm = class(TForm)
    Memo1: TMemo;
    Button1: TButton;
    procedure Button1Click(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  EmailForm: TEmailForm;

implementation

{$R *.dfm}

procedure TEmailForm.Button1Click(Sender: TObject);
var email: string;
    RetVal: integer;
begin
    email := 'mailto:richersimulations@gmail.com'
    + '?subject=TBPB 2020 User Feedback'
    + '&body=test'+Memo1.Text;
  RetVal := ShellExecute(Handle, 'open', PChar(email), nil, nil, SW_SHOWNORMAL);
  if RetVal <= 32 then
    MessageDlg('Cannot find program to send e-mail.', mtWarning, [mbOK], 0);}

  EmailForm.Close;
end;

end.
